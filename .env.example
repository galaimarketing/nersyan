# Admin dashboard login (server-side, required for /admin).
# Set a username, a strong password, and a random session secret (e.g. `openssl rand -hex 32`).
# The session cookie is signed with ADMIN_SESSION_SECRET — changing it logs everyone out.
# ADMIN_USERNAME=youradmin
# ADMIN_PASSWORD=a-strong-password
# ADMIN_SESSION_SECRET=replace-with-64-hex-chars

# Postgres connection string (Neon or Vercel Postgres).
# Copy to .env.local and fill in your URL. Run lib/db/schema.sql once in your database.
# DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Supabase Storage (recommended, free tier) – for admin Media uploads.
# 1. Create a project at https://supabase.com 2. Project Settings → API: copy URL and service_role key.
# 3. Storage: create a bucket named "media", set it to Public.
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# SUPABASE_MEDIA_BUCKET=media

# Supabase Auth – for Google/Apple sign-in. Use the same project URL and the anon (public) key from API.
# Authentication → URL Configuration: add http://localhost:3000/auth/callback (and production /auth/callback).
# Google: Authorized redirect URI in Google Cloud = https://<project-ref>.supabase.co/auth/v1/callback
# Apple: In Apple Developer (Services ID → Web), Return URL must be https://<project-ref>.supabase.co/auth/v1/callback
#        (NOT localhost — Apple talks to Supabase first.) See docs/SUPABASE_SOCIAL_LOGIN.md
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Moyasar Payments — Invoice (hosted payment link)
# Server creates an invoice and redirects the customer to Moyasar’s checkout URL.
# Same base URL for test and live: https://api.moyasar.com/v1 — the secret key selects the mode (sk_test_ vs sk_live_).
# Optional but recommended in production: set to your public https origin so callback/success URLs match your domain.
# NEXT_PUBLIC_SITE_URL=https://yourdomain.com
#
# Local / staging (no real charges):
# MOYASAR_SECRET_KEY=sk_test_...
#
# Production (real cards — real charges):
# 1. Complete Moyasar live onboarding in the dashboard (business verification, etc.).
# 2. Vercel → Project → Settings → Environment Variables → Production:
#    MOYASAR_SECRET_KEY=sk_live_...
# 3. Keep sk_test_ on Preview/Development so preview deploys never charge real cards.
# 4. Site must use HTTPS. Callback URLs use your request host automatically.
# 5. In Moyasar, allow webhook/callback: https://yourdomain.com/api/moyasar/invoice-webhook
#
# Webhook: register https://yourdomain.com/api/moyasar/invoice-webhook if Moyasar asks for it.
# Set a "Secret Token" on the webhook in the Moyasar dashboard and mirror it here.
# When set, the webhook rejects any call whose secret_token does not match.
# MOYASAR_WEBHOOK_SECRET=your-webhook-secret-token

# Vercel Blob – optional fallback if Supabase is not set. Create a Blob store in Vercel Dashboard.
# BLOB_READ_WRITE_TOKEN=

# Hotel calendar for occupancy / “room booked” (date-only stay strings). Default: Asia/Riyadh.
# NEXT_PUBLIC_HOTEL_TIMEZONE=Asia/Riyadh
