# Postgres connection string (Neon or Vercel Postgres).
# Copy to .env.local and fill in your URL. Run lib/db/schema.sql once in your database.
# DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Vercel Blob – for persistent image uploads (admin Media). Create a Blob store in Vercel Dashboard to get this.
# BLOB_READ_WRITE_TOKEN=
